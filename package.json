{
  "name": "docker_web_app",
  "version": "1.0.0",
  "description": "Node.js on Docker",
  "author": "First Last <first.last@example.com>",
  "main": "dist/server.js",
  "private": true,
  "scripts": {
    "start": "ts-node src/server.ts",
    "build": "tsc",
    "dev": "NODE_ENV=development ts-node-dev --respawn --transpile-only src/server.ts",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\"",
    "prepare": "husky install"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "express": "^4.20.0"
  },
  "devDependencies": {
    "husky": "^8.0.0",
    "lint-staged": "^14.0.0",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "src/**/*.{ts,js,json,md}": [
      "prettier --write",
      "git add"
    ]
  }
}
